# Finnhub (primary news per ticker)
FINNHUB_API_KEY=your_finnhub_key

# CryptoPanic (crypto sector only)
CRYPTOPANIC_API_KEY=your_cryptopanic_key

# Alpha Vantage (supplementary news per sector)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Reddit (optional — leave blank to skip; see docs/SETUP-SERVICES.md if you want to enable)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot/1.0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# Alpaca (use paper keys first)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# NLP (choose one)
OPENAI_API_KEY=your_openai_key

# Risk Parameters
MAX_POSITION_SIZE_PCT=0.05
MAX_DAILY_TRADES=10
MIN_SIGNAL_CONFIDENCE=0.65
SIGNAL_DEDUP_WINDOW_MINUTES=30

# Daily performance email (SMTP — e.g. Gmail App Password)
REPORT_EMAIL_TO=
REPORT_EMAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
